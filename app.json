{
  "expo": {
    "name": "Indie",
    "slug": "indie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/indie_rem.png",
    "scheme": "me.ritom.indie",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "me.ritom.indie",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
      }
    },
    "android": {
      "package": "me.ritom.indie",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Indie accesses your photos to let you create pins.",
          "cameraPermission": "Indie accesses your camera to let you create pins."
        }
      ],
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      "expo-status-bar",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/indie.jpeg",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "61931d90-c63d-46a3-8b9e-13e2283aa2b2"
      }
    },
    "owner": "ritomg",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/61931d90-c63d-46a3-8b9e-13e2283aa2b2"
    }
  }
}
